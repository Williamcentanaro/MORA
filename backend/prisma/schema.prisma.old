generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  password               String
  name                   String?
  role                   Role           @default(USER)
  emailVerified          Boolean        @default(false)
  emailVerificationToken String?
  resetPasswordToken     String?
  resetPasswordExpires   DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  followedRestaurants    Follower[]
  notifications          Notification[]
  ownerRequest           OwnerRequest?
  restaurants            Restaurant[]
}

model OwnerRequest {
  id           String           @id @default(uuid())
  userId       String           @unique
  status       RestaurantStatus @default(PENDING)
  businessName String
  city         String
  message      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id])
}

model Restaurant {
  id            String           @id @default(uuid())
  name          String
  description   String?
  address       String
  city          String
  phone         String?
  latitude      Float?
  longitude     Float?
  logo          String?
  coverImage    String?
  status        RestaurantStatus @default(PENDING)
  ownerId       String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  gallery       Json?
  images        String?
  menuImages    Json?
  menuMode      String?          @default("MANUAL")
  menuPdf       String?
  events        Event[]
  followers     Follower[]
  menus         Menu[]
  notifications Notification[]
  openingHours  OpeningHour[]
  owner         User             @relation(fields: [ownerId], references: [id])
}

model OpeningHour {
  id           String     @id @default(uuid())
  dayOfWeek    Int
  openTime     String
  closeTime    String
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model Menu {
  id           String     @id @default(uuid())
  title        String
  description  String?
  type         MenuType   @default(REGULAR)
  content      Json
  isActive     Boolean    @default(true)
  restaurantId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  date         DateTime?
  price        Float?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model Event {
  id           String     @id @default(uuid())
  title        String
  description  String?
  date         DateTime
  location     String?
  image        String?
  restaurantId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model Follower {
  id           String     @id @default(uuid())
  userId       String
  restaurantId String
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@unique([userId, restaurantId])
}

model Notification {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  type         String
  title        String
  message      String
  isRead       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  OWNER
  ADMIN
}

enum RestaurantStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MenuType {
  DAILY
  REGULAR
}
