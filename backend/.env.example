# ==========================================
# MORA PROJECT - BACKEND CONFIGURATION
# ==========================================

# --- 1. CORE CONFIGURATION ---
PORT=5000
JWT_SECRET=provide_a_secure_random_string_here
# Local: file:./prisma/dev.db
# Prod:  file:/var/www/mora/backend/prisma/dev.db
DATABASE_URL="file:./prisma/dev.db"

# --- 2. CORS & REDIRECTION ---
# List of origins allowed to make requests (comma separated)
# Example Local: http://localhost:5173
# Example Prod:  https://moraapp.it,https://www.moraapp.it
ALLOWED_ORIGINS="http://localhost:5173"

# Essential for Auth Redirects/Emails
# Example Local: http://localhost:5173
# Example Prod:  https://moraapp.it
FRONTEND_URL="http://localhost:5173"

# --- 3. SOCIAL AUTH (GOOGLE) ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Example Local: http://localhost:5000/api/auth/google/callback
# Example Prod:  https://moraapp.it/api/auth/google/callback
GOOGLE_REDIRECT_URI="http://localhost:5000/api/auth/google/callback"

# --- 4. SOCIAL AUTH (FACEBOOK) ---
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
# Example Local: http://localhost:5000/api/auth/facebook/callback
# Example Prod:  https://moraapp.it/api/auth/facebook/callback
FACEBOOK_REDIRECT_URI="http://localhost:5000/api/auth/facebook/callback"

# --- 5. NOTIFICATIONS ---
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# --- 6. SMTP (EMAIL SERVICE) ---
# If these are missing, the system falls back to console logging (Dev Mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
